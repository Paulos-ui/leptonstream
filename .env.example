# LeptonStream — environment

# Optional: override the Circle Gateway facilitator (defaults to testnet).
# FACILITATOR_URL=https://gateway-api-testnet.circle.com

# Set to 1 to force DEMO mode app-wide (no wallet/funds needed; payments
# are simulated by the MockAdapter so the demo can never break on stage).
# Leave unset for real Arc-testnet settlement. You can also append ?demo=1
# to any /watch link to demo a single session.
NEXT_PUBLIC_DEMO=
